# getIt — environment variables
# Copy to .env.local and fill in. Nothing here is required for the Phase 1
# mock UI; these are placeholders for the upcoming backend phases.

# --- Database (Phase 2: Prisma + PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/getit?schema=public"

# --- Auth (Phase 2: Auth.js v5) ---
AUTH_SECRET=""

# --- OTP (Phase 2: MSG91, India) ---
MSG91_AUTH_KEY=""
MSG91_OTP_TEMPLATE_ID=""
MSG91_SENDER_ID=""

# --- Storage (Phase 3: Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# --- Payments (Phase 4: PayU) ---
PAYU_MERCHANT_KEY=""
PAYU_MERCHANT_SALT=""
PAYU_MODE="test" # test | live

# --- Logistics (Phase 5: ShipRocket) ---
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
